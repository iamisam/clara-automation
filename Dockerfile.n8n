FROM n8nio/n8n:latest

USER root

# Install Python (Debian-based)
RUN apt-get update && \
    apt-get install -y python3 python3-pip && \
    pip3 install --break-system-packages \
    faster-whisper \
    ollama \
    python-dotenv && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

USER node
